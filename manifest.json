{
  "manifest_version": 3,
  "name": "UNV Downloader - Video Detector & Downloader",
  "version": "1.0",
  "description": "Detects and downloads videos (HTML5 & HLS/m3u8) directly from any webpage.",
  "icons": {
    "16": "logo/icon-16.png",
    "32": "logo/icon-32.png",
    "48": "logo/icon-48.png",
    "128": "logo/icon-128.png"
  },
  "permissions": [
    "webRequest",
    "downloads",
    "storage",
    "activeTab",
    "offscreen",
    "declarativeNetRequest",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["youtube-main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "UNV Downloader",
    "default_icon": {
      "16": "logo/icon-16.png",
      "32": "logo/icon-32.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["hls-parser.js", "downloader.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
